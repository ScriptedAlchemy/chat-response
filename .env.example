HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
SQLITE_PATH=.data/chat-response.db

# Optional inbound auth for clients calling this adapter.
ADAPTER_API_KEY=

# Upstream chat-completions provider configuration.
UPSTREAM_BASE_URL=https://api.openai.com
UPSTREAM_CHAT_PATH=/v1/chat/completions
UPSTREAM_API_KEY=
UPSTREAM_AUTH_MODE=bearer
UPSTREAM_API_KEY_HEADER=Authorization
UPSTREAM_QUERY_PARAMS={}
UPSTREAM_HEADERS={}

# Capability toggles for imperfect providers.
UPSTREAM_SUPPORTS_DEVELOPER_ROLE=true
UPSTREAM_SUPPORTS_AUDIO_INPUT=true
UPSTREAM_SUPPORTS_FILE_PARTS=true
