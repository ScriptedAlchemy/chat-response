{
  "name": "chat-response",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Stateful adapter that exposes OpenAI Responses API over chat-completions-only providers",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "dev:worker": "wrangler dev",
    "deploy:worker": "wrangler deploy",
    "cf:login": "wrangler login",
    "cf:d1:create": "wrangler d1 create chat-response",
    "d1:migrate": "wrangler d1 migrations apply chat-response --remote",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.0",
    "@types/node": "^22.13.10",
    "playwright": "^1.58.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8",
    "wrangler": "^4.75.0"
  }
}
